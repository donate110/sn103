# Bittensor
BT_NETUID=103
BT_NETWORK=finney
BT_WALLET_NAME=default
BT_WALLET_HOTKEY=default

# Miner API
API_HOST=0.0.0.0
API_PORT=8422

# CORS origins (comma-separated, leave empty for wildcard in dev)
# CORS_ORIGINS=https://app.djinn.com,https://staging.djinn.com

# The Odds API — get a key at https://the-odds-api.com
ODDS_API_KEY=your-odds-api-key-here
ODDS_API_BASE_URL=https://api.the-odds-api.com

# Cache TTL in seconds for odds data (0 = no caching)
ODDS_CACHE_TTL=30

# Line matching tolerance (0.0 = exact match only, the line must exist at that exact value)
LINE_TOLERANCE=0.0

# TLSNotary — peer notary is assigned by the validator per-request.
# No centralized fallback; every miner runs its own notary sidecar.
# TLSN_PROVER_BINARY=djinn-tlsn-prover  # Auto-downloaded if not set

# Peer Notary Sidecar (enabled by default — every miner acts as a notary for peers)
# NOTARY_ENABLED=true                 # Set to false to disable (hurts scoring)
# NOTARY_PORT=7047                    # Local TCP port (localhost only, proxied via /v1/notary/ws)
# NOTARY_KEY_PATH=~/.local/share/djinn/notary-key.bin

# Rate limiting (requests per window)
RATE_LIMIT_CAPACITY=30
RATE_LIMIT_RATE=5

# Timeouts (seconds) — defaults shown
HTTP_TIMEOUT=30

# Logging — defaults shown
LOG_FORMAT=console
LOG_LEVEL=INFO
