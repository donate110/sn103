# Required: Deployer wallet with USDC minting rights + ETH for gas
E2E_DEPLOYER_KEY=0x...

# Required: Genius test wallet private key
E2E_GENIUS_KEY=0x...

# Optional: Vercel automation bypass secret (from Vercel project Settings > Security)
# This is the most reliable way to bypass the Vercel Security Checkpoint.
# Set VERCEL_AUTOMATION_BYPASS_SECRET in the Vercel project, then copy the value here.
VERCEL_BYPASS_SECRET=

# Optional: Target URL (default: https://djinn.gg)
UX_BASE_URL=https://djinn.gg

# Optional: Seed for deterministic idiot wallet derivation (default: djinn-ux-test-2026)
UX_WALLET_SEED=djinn-ux-test-2026

# Optional: Show browser window (default: headless)
UX_HEADED=0
