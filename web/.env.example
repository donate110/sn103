# WalletConnect project ID from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id-here

# Base chain RPC URL
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# Expected chain ID (84532 = Base Sepolia testnet, 8453 = Base mainnet)
NEXT_PUBLIC_CHAIN_ID=84532

# Contract addresses (deployed on Base Sepolia testnet)
NEXT_PUBLIC_SIGNAL_COMMITMENT_ADDRESS=0x4712479Ba57c9ED40405607b2B18967B359209C0
NEXT_PUBLIC_ESCROW_ADDRESS=0xb43BA175a6784973eB3825acF801Cd7920ac692a
NEXT_PUBLIC_COLLATERAL_ADDRESS=0x71F0a8c6BBFc4C83c5203807fAdd305B0C0F4C88
NEXT_PUBLIC_CREDIT_LEDGER_ADDRESS=0xA65296cd11B65629641499024AD905FAcAB64C3E
NEXT_PUBLIC_ACCOUNT_ADDRESS=0x4546354Dd32a613B76Abf530F81c8359e7cE440B
NEXT_PUBLIC_AUDIT_ADDRESS=0xCa7e642FE31BA83a7a857644E8894c1B93a2a44E
NEXT_PUBLIC_KEY_RECOVERY_ADDRESS=0x496919DB9BC4590323cd019fE874311AC6116525
NEXT_PUBLIC_USDC_ADDRESS=0x00e8293b05dbD3732EF3396ad1483E87e7265054

# Block number when contracts were first deployed (speeds up event scanning)
NEXT_PUBLIC_DEPLOY_BLOCK=0

# Bittensor metagraph discovery (enables auto-discovery of validators/miners)
# When BT_NETWORK is set, VALIDATOR_URL and MINER_URL become optional fallbacks
BT_NETUID=103
BT_NETWORK=finney
# BT_RPC_URL=https://entrypoint-finney.opentensor.ai  # Override RPC endpoint

# Off-chain service URLs (optional — auto-discovered from metagraph if BT_NETWORK is set)
# Manual override: comma-separated for multiple validators
# VALIDATOR_URL=http://localhost:8421
# MINER_URL=http://localhost:8422

# Subgraph URL (The Graph hosted service or local Graph node)
NEXT_PUBLIC_SUBGRAPH_URL=

# Beta gate password (server-side only, verified via /api/beta/verify)
# Leave empty to disable the beta gate
BETA_PASSWORD=

# Shamir secret sharing parameters
# THRESHOLD=1 for dev/testnet (single validator), 7 for mainnet
NEXT_PUBLIC_SHAMIR_TOTAL=10
NEXT_PUBLIC_SHAMIR_THRESHOLD=1

# The Odds API key (server-side only — get one at https://the-odds-api.com)
ODDS_API_KEY=your-odds-api-key-here

# Error reporting — GitHub issue creation (server-side only)
# Create a fine-grained PAT at https://github.com/settings/personal-access-tokens
# with "Issues: Read and write" permission on the error-reports repo
GITHUB_ERROR_TOKEN=
ERROR_REPORT_REPO=djinn-inc/error-reports

# Taostats API key (server-side only — get one at https://dash.taostats.io)
# Used for validator/miner name resolution in admin dashboard
TAOSTATS_API_KEY=

# Admin dashboard password (server-side API auth)
ADMIN_PASSWORD=change-me-in-production

# API session signing secret (falls back to ADMIN_PASSWORD if unset; one must be set)
# API_SESSION_SECRET=

# Cron job secret (required for /api/cron/* endpoints)
CRON_SECRET=

# Validator endpoints override for /api/network/config (comma-separated uid:name:endpoint)
# Defaults to metagraph discovery; falls back to built-in list if discovery fails
# VALIDATOR_ENDPOINTS=2:Yuma:http://34.58.165.14:8421,41:Djinn:http://37.60.251.252:8421

# Outcome voting contract
NEXT_PUBLIC_OUTCOME_VOTING_ADDRESS=0xAD534f4CAB13707BD4d65e4EF086A455e6A643e5

# Privy authentication (optional, for wallet connection UX)
# NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id

# Off-chain service URLs (optional — auto-discovered from metagraph)
# Set explicitly to bypass metagraph discovery
VALIDATOR_URL=
MINER_URL=
NEXT_PUBLIC_VALIDATOR_URL=
NEXT_PUBLIC_MINER_URL=

# E2E test wallet (testnet only, never use on mainnet)
# E2E_TEST_PRIVATE_KEY=
