# Bittensor
BT_NETUID=103
BT_NETWORK=finney
BT_WALLET_NAME=default
BT_WALLET_HOTKEY=default

# Weight burn: fraction of total weight allocated to UID 0 (subnet owner)
BT_BURN_FRACTION=0.95

# Base chain RPC (comma-separated for failover, e.g. https://mainnet.base.org,https://base.llamarpc.com)
BASE_RPC_URL=https://mainnet.base.org
BASE_CHAIN_ID=8453

# Validator private key for signing outcome settlement transactions on Base
# The derived address must be added as an authorizedCaller on both Account and Escrow contracts
# BASE_VALIDATOR_PRIVATE_KEY=0x...

# Contract addresses (UUPS proxies on Base Sepolia — deployed 2026-03-22)
ESCROW_ADDRESS=0xb43BA175a6784973eB3825acF801Cd7920ac692a
SIGNAL_COMMITMENT_ADDRESS=0x4712479Ba57c9ED40405607b2B18967B359209C0
ACCOUNT_ADDRESS=0x4546354Dd32a613B76Abf530F81c8359e7cE440B
COLLATERAL_ADDRESS=0x71F0a8c6BBFc4C83c5203807fAdd305B0C0F4C88
AUDIT_ADDRESS=0xCa7e642FE31BA83a7a857644E8894c1B93a2a44E
OUTCOME_VOTING_ADDRESS=0xAD534f4CAB13707BD4d65e4EF086A455e6A643e5

# Validator API
API_HOST=0.0.0.0
API_PORT=8421

# External IP/port for metagraph discovery (set if behind NAT/proxy)
# EXTERNAL_IP=1.2.3.4
# EXTERNAL_PORT=8421

# CORS origins (required in production — comma-separated)
CORS_ORIGINS=https://djinn.gg,https://www.djinn.gg

# Auto-update from main branch (recommended)
AUTO_UPDATE=true
AUTO_UPDATE_BRANCH=main

# Sports data: validator uses ESPN's free public API (no key needed).
# SPORTS_API_KEY is deprecated and ignored if set.

# Timeouts (seconds) — defaults shown
HTTP_TIMEOUT=30
RPC_TIMEOUT=30

# MPC settings
MPC_PEER_TIMEOUT=10.0
MPC_AVAILABILITY_TIMEOUT=15.0

# Rate limiting (requests per window)
# RATE_LIMIT_CAPACITY=60
# RATE_LIMIT_RATE=10

# Logging — defaults shown
LOG_FORMAT=console
LOG_LEVEL=INFO
