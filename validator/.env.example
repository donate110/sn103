# Bittensor
BT_NETUID=103
BT_NETWORK=finney
BT_WALLET_NAME=default
BT_WALLET_HOTKEY=default

# Base chain RPC (comma-separated for failover, e.g. https://mainnet.base.org,https://base.llamarpc.com)
BASE_RPC_URL=https://mainnet.base.org
BASE_CHAIN_ID=8453

# Validator private key for signing outcome settlement transactions on Base
# The derived address must be added as an authorizedCaller on both Account and Escrow contracts
# BASE_VALIDATOR_PRIVATE_KEY=0x...

# Contract addresses (checksummed Base addresses, set after deployment)
ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
SIGNAL_COMMITMENT_ADDRESS=0x0000000000000000000000000000000000000000
ACCOUNT_ADDRESS=0x0000000000000000000000000000000000000000
COLLATERAL_ADDRESS=0x0000000000000000000000000000000000000000
OUTCOME_VOTING_ADDRESS=0x0000000000000000000000000000000000000000

# Validator API
API_HOST=0.0.0.0
API_PORT=8421

# External IP/port for metagraph discovery (set if behind NAT/proxy)
# EXTERNAL_IP=1.2.3.4
# EXTERNAL_PORT=8421

# CORS origins (comma-separated, leave empty for wildcard in dev)
# CORS_ORIGINS=https://app.djinn.com,https://staging.djinn.com

# Sports data: validator uses ESPN's free public API (no key needed).
# SPORTS_API_KEY is deprecated and ignored if set.

# Timeouts (seconds) — defaults shown
HTTP_TIMEOUT=30
RPC_TIMEOUT=30

# MPC settings
MPC_PEER_TIMEOUT=10.0
MPC_AVAILABILITY_TIMEOUT=15.0

# Rate limiting (requests per window)
# RATE_LIMIT_CAPACITY=60
# RATE_LIMIT_RATE=10

# Logging — defaults shown
LOG_FORMAT=console
LOG_LEVEL=INFO
